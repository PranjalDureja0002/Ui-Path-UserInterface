# ── UiPath ───────────────────────────────────────────────────────────────────
# UIPATH_URL / UIPATH_ACCESS_TOKEN / UIPATH_TENANT_ID / UIPATH_ORGANIZATION_ID
# are written automatically by:  uipath auth --staging --tenant <YourTenant> --force
UIPATH_PROJECT_ID=<your-project-guid>

# ── Neo4j AuraDB (env-first; cloud reads Assets Neo4j-Uri/User/Pass/Database) ──
NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USERNAME=<instance-id-or-neo4j>
NEO4J_PASSWORD=<your-aura-password>
NEO4J_DATABASE=<instance-id-or-neo4j>

# ── FOREMAN view-backend (local dev only; cloud uses Assets / agent input) ────
# FOREMAN_BACKEND_URL=http://localhost:8000
# FOREMAN_INGEST_SECRET=dev-secret
