# ── FOREMAN UI feed mode ─────────────────────────────────────────────────────
# demo = play the scripted DEL-0473 / MUM-0210 scenarios (default)
# live = bind to a real CaseEvent stream over WebSocket from the view-backend
VITE_FEED_MODE=demo
VITE_FEED_WS_URL=ws://localhost:8000/ws

# Copy to `.env` and set VITE_FEED_MODE=live to go real-time.
